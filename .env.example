# ParkClean Manager - Environment Configuration
# Copy this file to .env and modify the values

# Application
APP_NAME="ParkClean Manager"
APP_ENV=development        # development, production, testing
APP_DEBUG=true            # true or false
APP_URL=http://localhost:8000

# Database
DB_PATH=database/parkclean.db

# Security
# Pour la production, générer une clé avec: openssl rand -base64 32
APP_KEY=your-32-character-secret-key-here
SESSION_LIFETIME=3600

# Logging
LOG_PATH=logs
LOG_LEVEL=debug           # debug, info, warning, error

# File Upload
UPLOAD_MAX_SIZE=5242880   # 5MB en octets
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif

# Rate Limiting
RATE_LIMIT_ENABLED=false  # true or false (pour production)
RATE_LIMIT_REQUESTS=100   # nombre de requêtes max
RATE_LIMIT_WINDOW=60      # fenêtre de temps en secondes

# Email (optionnel - pour les notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@parkclean.local

